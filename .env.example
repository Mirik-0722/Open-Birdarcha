# Deploy sozlamalari. Bu faylni .env ga nusxalang:  cp .env.example .env

# ---- PostgreSQL ulanishi (postgres:// formatida — entrypoint jdbc'ga o'giradi) ----
# Haqiqiy qiymatni .env ga yozing — bu fayl faqat shablon, sir saqlanmaydi.
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DB_NAME

# DB'da allaqachon jadvallar bo'lsa (Flyway tarixisiz) — true qiling:
FLYWAY_BASELINE_ON_MIGRATE=false

# ---- Tashqi portlar ----
FRONTEND_PORT=8010
BACKEND_PORT=8011
