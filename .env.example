# Deploy sozlamalari. Bu faylni .env ga nusxalang:  cp .env.example .env

# ---- PostgreSQL ulanishi (postgres:// formatida — entrypoint jdbc'ga o'giradi) ----
# Haqiqiy qiymatni .env ga yozing — bu fayl faqat shablon, sir saqlanmaydi.
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DB_NAME

# DB'da allaqachon jadvallar bo'lsa (Flyway tarixisiz) — true qiling:
FLYWAY_BASELINE_ON_MIGRATE=false

# ---- Tashqi portlar ----
FRONTEND_PORT=8010
BACKEND_PORT=8011

# ---- Auth (Telegram bot) ----
# @BotFather'dan: bot token va bot username (@ belgisisiz).
TELEGRAM_BOT_TOKEN=8781596266:AAEXYHBwn2EROUJtfCg8CfT_rJaHJZSYMwg
TELEGRAM_BOT_USERNAME=open_birdarcha_login_bot
AUTH_TOKEN_SECRET=secret-key-for-auth-token-which-should-be-changed-in-production
AUTH_TOKEN_TTL_SECONDS=86400

# ---- CORS ----
# Frontend domeni (vergul bilan bir nechta bo'lishi mumkin). Brauzer Origin'i shu bilan mos kelishi shart.
APP_CORS_ALLOWED_ORIGINS=https://open.birdarcha.mirikdev.uz

# ---- Vaqt zonasi ----
# Konteyner va ilova zonasi (loglar, now(), API sana/vaqti). UTC o'rniga local.
APP_TIMEZONE=Asia/Tashkent
